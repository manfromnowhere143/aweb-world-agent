# Aweb Agent for World — environment

# World Developer Portal (create at developer.worldcoin.org). Until set, app runs in DEV/MOCK mode.
NEXT_PUBLIC_WORLD_APP_ID=app_staging_xxxxxxxxxxxxxxxxxxxxxxxx
WORLD_ACTION_VERIFY_HUMAN=verify-human
WORLD_ACTION_APPROVE_MISSION=approve-mission

# Agent brain (reused from Aweb's funded keys — copy the values, do not commit)
ANTHROPIC_API_KEY=

# Dev/mock toggle: when true (or App ID unset), World ID/wallet are simulated so the
# full governed loop is buildable and testable outside World App.
WORLD_AGENT_DEV_MODE=true
